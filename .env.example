# ─── NeuroRAG Environment Variables ──────────────────────────────────────────
# Copy to .env and fill in all values before running `make up`

# LLM
OPENAI_API_KEY=sk-...

# API auth (generate with: make generate-api-key)
NEURORAG_API_KEY=

# Airflow security keys (generate with: make generate-airflow-keys)
AIRFLOW_FERNET_KEY=
AIRFLOW_SECRET_KEY=

# Grafana
GRAFANA_PASSWORD=admin

# Alerting
ALERT_EMAIL=ops@neurorag.io
ALERT_SMTP_USER=
ALERT_SMTP_PASSWORD=
