# ─── NeuroRAG Environment Variables ──────────────────────────────────────────
# Copy to .env and fill in values, then run: . .\load_env.ps1

# LLM — Required (OpenAI API key for generator + critic)
OPENAI_API_KEY=sk-...

# API auth key — generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
NEURORAG_API_KEY=

# Database — PostgreSQL (create user/db with psql commands in README)
POSTGRES_URL=
# Cache — Redis (optional; API starts fine without it)
REDIS_URL=redis://localhost:6379

# Airflow keys (only needed if running Airflow MLOps pipelines)
AIRFLOW_FERNET_KEY=
AIRFLOW_SECRET_KEY=

# Grafana (only needed if running Grafana dashboard)
GRAFANA_PASSWORD=admin

# Alerting (only needed if running Alertmanager)
ALERT_EMAIL=ops@neurorag.io
ALERT_SMTP_USER=
ALERT_SMTP_PASSWORD=
